# ─── Database (TiDB – MySQL-compatible) ────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/cplatform?ssl_verify_cert=false

# ─── JWT ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Cerebras AI  (add as many keys as you have; unused slots are ignored) ──
# Model: verify exact name at https://inference.cerebras.ai/
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_API_KEY_1=csk-xxxxxxxxxxxx
CEREBRAS_API_KEY_2=csk-xxxxxxxxxxxx
CEREBRAS_API_KEY_3=csk-xxxxxxxxxxxx
CEREBRAS_API_KEY_4=csk-xxxxxxxxxxxx

# ─── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
